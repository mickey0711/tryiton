# Database
DATABASE_URL=postgresql://tryiton:tryiton@localhost:5432/tryiton

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3 (use LocalStack for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=tryiton-local
S3_ENDPOINT=http://localhost:4566

# Auth
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email (use console transport for local dev)
EMAIL_TRANSPORT=console
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tryiton.ai

# API
PORT=8080
CORS_ORIGINS=chrome-extension://,http://localhost:3000

# AI Provider (mock | replicate | segmind)
# mock  = offline PIL compositing — no API key needed
# replicate = set REPLICATE_API_TOKEN below
# segmind   = set SEGMIND_API_KEY below
AI_PROVIDER=mock

# Replicate (https://replicate.com)
REPLICATE_API_TOKEN=
# Model: default is IDM-VTON (best quality for clothing)
REPLICATE_MODEL_TRYON=cuuupid/idm-vton:906425dbca90663ff5427624839572cc56ea7d380343d13e2a4c4b09d7d0add5

# Segmind (https://segmind.com) — cheaper, faster
SEGMIND_API_KEY=
SEGMIND_ENDPOINT=https://api.segmind.com/v1/virtual-try-on

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=info
ENV=development

# App URLs
WEB_APP_URL=http://localhost:3000
API_URL=http://localhost:8080
